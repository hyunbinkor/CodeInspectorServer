# ═══════════════════════════════════════════════════════════════════════════
# Code Inspector Server — 환경 변수 템플릿
#
# 사용법:
#   1. 이 파일을 .env로 복사:   copy .env.example .env   (Windows)
#                                cp   .env.example .env   (Linux/macOS)
#   2. 아래 값들을 운영 환경에 맞게 채워 넣기
#   3. .env 파일은 절대 커밋하지 말 것 (.gitignore에 등록되어 있음)
# ═══════════════════════════════════════════════════════════════════════════

# ─── 서버 ──────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# CORS 허용 도메인. 쉼표로 구분, * 는 모두 허용 (운영에서는 화이트리스트 권장).
# 예: CORS_ORIGIN=http://localhost:8080,https://ide.example.internal
CORS_ORIGIN=*

# ─── vLLM (LLM 추론 서버) ──────────────────────────────────────────────────
# OpenAI 호환 API 엔드포인트. 내부망 IP/포트로 교체.
VLLM_BASE_URL=http://CHANGE_ME:11434
VLLM_MODEL=CHANGE_ME
VLLM_TIMEOUT=180000
VLLM_MAX_RETRIES=3
VLLM_MAX_TOKENS=64000
# 각 LLM 호출 사이 지연 (ms). vLLM rate limit이 있을 때만 0보다 큰 값 권장.
VLLM_REQUEST_DELAY_MS=0
# 청크 병렬 처리 동시성. vLLM 용량에 맞춰 조정 (1~10 권장).
CHUNK_CONCURRENCY=3

# ─── Qdrant (벡터 DB) ──────────────────────────────────────────────────────
QDRANT_HOST=CHANGE_ME
QDRANT_PORT=443
QDRANT_HTTPS=true
QDRANT_COLLECTION=rules               # 가이드라인 규칙 컬렉션
QDRANT_ISSUE_COLLECTION=issues        # 이슈 기반 규칙 컬렉션 (없으면 빈 값)
QDRANT_TAG_COLLECTION=tag-definitions # 태그 정의 컬렉션

# ─── 경로 (Windows 개발 환경 주의) ─────────────────────────────────────────
# 기본값은 /tmp/... (Linux 컨테이너 전용).
# Windows 로컬에서 실행하려면 절대 경로로 명시 필요.
# 예: TAGS_PATH=C:\Users\YOU\AppData\Local\Temp\code-inspector\tags
TAGS_PATH=/tmp/tags
BACKUP_PATH=/tmp/backup

# ─── TLS 검증 ──────────────────────────────────────────────────────────────
# 내부망에서 자체 서명 인증서를 사용하는 경우에만 0으로 설정.
# 운영에서는 가능하면 CA 체인을 컨테이너에 마운트하여 1로 둘 것.
# NODE_TLS_REJECT_UNAUTHORIZED=0

# ─── 로깅 ──────────────────────────────────────────────────────────────────
# error | warn | info | debug | trace
LOG_LEVEL=info
